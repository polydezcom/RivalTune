{
    "id" : "com.polydez.rivaltune",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "48",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "rivaltune",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=all",
        "--socket=wayland",
        "--filesystem=/run/udev:ro",
        "--filesystem=/sys/bus/usb:ro",
        "--filesystem=/sys/bus/hid:ro"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin",
        "env" : {
            "RUST_BACKTRACE" : "1"
        }
    },
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        "python3-rivalcfg.json",
        {
            "name" : "rivaltune",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/polydezcom/RivalTune/archive/refs/tags/v1.8.4.tar.gz",
                    "sha256" : "36b251b9b0ef91b2e4ebb4ddae9916ec7861ce433af15f8c164a2d0fd7aa6c12"
                },
                {
                    "type" : "file",
                    "path" : "cargo-sources.json"
                },
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir -p .cargo",
                        "cp -f cargo/config .cargo/config.toml"
                    ]
                }
            ]
        }
    ]
}
