{
    "id" : "com.polydez.rivaltune",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "48",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "rivaltune",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=all",
        "--socket=wayland",
        "--talk-name=org.freedesktop.PolicyKit1",
        "--system-talk-name=org.freedesktop.UDisks2",
        "--filesystem=/run/udev:ro",
        "--filesystem=/sys/bus/usb:ro",
        "--filesystem=/sys/bus/hid:ro"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin",
        "build-args" : [
            "--share=network"
        ],
        "env" : {
            "RUST_BACKTRACE" : "1",
            "RUST_LOG" : "rivaltune=debug"
        }
    },
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        "python3-rivalcfg.json",
        {
            "name" : "rivaltune",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "file:///home/berk/Projects/RivalTune"
                }
            ]
        }
    ]
}
